# Copy this file to `.env` and fill in real values. Never commit `.env`.
#   cp .env.example .env

# ── ngrok (local tunnel for Slack → your laptop; not read by Python) ──
# Get your authtoken: https://dashboard.ngrok.com/get-started/your-authtoken
# Start tunnel:  bash scripts/ngrok-start.sh
# (Runs: ngrok http $NGROK_PORT --authtoken $NGROK_AUTHTOKEN)
NGROK_AUTHTOKEN=your-ngrok-authtoken-here
NGROK_PORT=8000

# ── Slack (required) ─────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
# Channel IDs: right-click channel in Slack → View channel details → copy ID
SLACK_CHANNEL_ID=C01234567890
SLACK_INCIDENT_CHANNEL_ID=C01234567890

# ── FireHydrant (required) ─────────────────────────────────────────
FIREHYDRANT_API_KEY=fhb-your-api-key

# ── Jira Cloud (required) ──────────────────────────────────────────
JIRA_DOMAIN=your-domain.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=SCRUM

# ── Ollama (required for AI features) ───────────────────────────────
# Local run: http://localhost:11434
# Docker Compose (this repo's docker-compose.yml): set automatically to http://ollama:11434
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
# Recommended for RCCA similarity search (run: ollama pull nomic-embed-text)
# OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120
OLLAMA_DRAFT_TIMEOUT=45
OLLAMA_USE_SINGLE_DRAFT=true

# ── FireHydrant milestones (optional; must match your org) ─────────
# FH_MILESTONE_SLUGS=acknowledged,investigating,identified,mitigated,resolved

# ── RCCA: local Google Drive sync folder OR Drive API (optional) ───
# A) Local path (macOS/Windows File Stream) — no Google API keys:
# RCCA_LOCAL_FOLDER=/Users/you/Library/CloudStorage/.../My Drive/RCCA folder
# B) Drive API:
# GDRIVE_RCCA_ENABLED=true
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# GDRIVE_RCCA_FOLDER_ID=your_folder_id
# GDRIVE_SIMILARITY_THRESHOLD=0.38
# GDRIVE_KEYWORD_WEIGHT=0.25
# RCCA_KEYWORD_ONLY_THRESHOLD=0.15

# ── New Relic (optional) ───────────────────────────────────────────
# NEW_RELIC_ENABLED=true
# NEW_RELIC_API_KEY=
# NEW_RELIC_ACCOUNT_ID=
# NEW_RELIC_REGION=us
# NR_MONITOR_INTERVAL_SEC=300
# NR_QUERY_WINDOW_MINUTES=30
